{
  "name": "campus-dining-api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "predb:seed": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "predb:import-collection": "prisma generate",
    "db:import-collection": "tsx scripts/import-menu-collection.ts",
    "predb:prune": "prisma generate",
    "db:prune": "tsx scripts/prune-old-data.ts",
    "precrawl:menus": "prisma generate",
    "crawl:menus": "tsx scripts/crawl-and-persist.ts",
    "precrawl:food-trucks": "prisma generate",
    "crawl:food-trucks": "tsx scripts/crawl-food-trucks.ts",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "pretest": "prisma generate",
    "start": "node dist/index.js",
    "test": "vitest run",
    "collect:live": "tsx scripts/collect-live-menus.ts",
    "collect:max-data": "DATE_FALLBACK_DAYS=120 tsx scripts/collect-live-menus.ts",
    "probe:menus": "tsx scripts/probe-menu-json.ts",
    "verify:live": "tsx scripts/verify-live-fetch.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cheerio": "^1.2.0",
    "hono": "^4.11.4",
    "pdf-parse": "^1.1.1",
    "pg": "^8.22.0",
    "playwright-core": "^1.61.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
